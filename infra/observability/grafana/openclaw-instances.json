{
  "uid": "phoenix-openclaw-instances",
  "title": "Phoenix OpenClaw Instances",
  "tags": ["phoenix", "openclaw", "instances"],
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "15s",
  "templating": {
    "list": [
      { "name": "instance", "type": "query", "query": "label_values(phoenix_openclaw_instance, instance)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Instance Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "phoenix_openclaw_instance_up", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Heartbeat Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "phoenix_agent_heartbeat_age_seconds * 1000", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Agent Count per Instance",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "phoenix_openclaw_agent_count", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "CPU per Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Memory per Node (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024", "legendFormat": "{{instance}}", "refId": "A" }
      ]
    }
  ]
}
