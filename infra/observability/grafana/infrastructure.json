{
  "uid": "phoenix-infrastructure",
  "title": "Phoenix Infrastructure",
  "tags": ["phoenix", "infrastructure", "postgres", "redis", "minio"],
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      { "name": "instance", "type": "query", "query": "label_values(up, instance)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "connections", "refId": "A" },
        { "expr": "pg_settings_max_connections", "legendFormat": "max", "refId": "B" }
      ]
    },
    {
      "id": 2,
      "title": "Redis Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "used", "refId": "A" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "max", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "title": "MinIO Storage Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "minio_bucket_usage_bytes", "legendFormat": "{{bucket}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Service Health (up)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "up{job=~\"phoenix-api|phoenix-bridge|node-exporter\"}", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"phoenix-api\"} / 1024 / 1024", "legendFormat": "api", "refId": "A" },
        { "expr": "process_resident_memory_bytes{job=\"phoenix-bridge\"} / 1024 / 1024", "legendFormat": "bridge", "refId": "B" }
      ]
    }
  ]
}
