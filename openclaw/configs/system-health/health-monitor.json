{
  "name": "System Health Monitor",
  "type": "monitoring",
  "role": "System & Agent Health Watchdog",
  "model": "gpt-4o-mini",
  "skills": [
    "agent-confidence-scorer", "llm-cost-tracker", "latency-monitor",
    "vector-db-retrospective", "multi-model-fallback", "audit-log-pdf",
    "hitl-discord-confirm", "hardware-thermal-alert", "sleep-mode-optimizer",
    "adversarial-red-team", "self-updating-prompt", "agent-performance-evaluator",
    "log-structured-output"
  ],
  "schedule": { "cron": "*/5 * * * *" },
  "config": {
    "confidence_min": 30,
    "latency_warn_ms": 500,
    "llm_budget_daily_usd": 50.0,
    "cpu_temp_max_c": 85,
    "publish_to": "stream:health-events"
  }
}
