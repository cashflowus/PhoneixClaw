# ═══════════════════════════════════════════════════════════════════════════
# Phoenix Claw — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=phoenixtrader
POSTGRES_PASSWORD=changeme
POSTGRES_DB=phoenixtrader
DATABASE_URL=postgresql+asyncpg://phoenixtrader:changeme@postgres:5432/phoenixtrader

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-generate-a-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MinIO (Object Storage) ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000

# ── OpenClaw Bridge ──────────────────────────────────────────────────────
BRIDGE_TOKEN=changeme-bridge-secret

# ── Broker (Alpaca) — leave blank for paper-only ─────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Ollama / LLM ─────────────────────────────────────────────────────────
OLLAMA_EXPAND_MODEL=llama3.2:1b

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Discord (optional) ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_TARGET_CHANNELS=
