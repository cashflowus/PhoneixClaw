# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP=default-group
KAFKA_AUTO_OFFSET_RESET=earliest

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://copytrader:localdev@localhost:5432/copytrader
POSTGRES_USER=copytrader
POSTGRES_PASSWORD=localdev
POSTGRES_DB=copytrader

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth / JWT ===
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Credential Encryption ===
CREDENTIAL_ENCRYPTION_KEY=generate-with-python-c-from-cryptography.fernet-import-Fernet;print(Fernet.generate_key().decode())

# === Alpaca (default broker for dev) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# === Discord ===
DISCORD_BOT_TOKEN=
DISCORD_TARGET_CHANNELS=

# === Risk Defaults ===
MAX_POSITION_SIZE=10
MAX_TOTAL_CONTRACTS=100
MAX_NOTIONAL_VALUE=50000.0
MAX_DAILY_LOSS=1000.0
TICKER_BLACKLIST=
ENABLE_TRADING=true
DRY_RUN_MODE=false

# === Execution ===
BUFFER_PERCENTAGE=0.15
BUFFER_MAX_PERCENTAGE=0.30
BUFFER_MIN_PRICE=0.01
BUFFER_OVERRIDES={}
DEFAULT_PROFIT_TARGET=0.30
DEFAULT_STOP_LOSS=0.20

# === Monitor ===
MONITOR_POLL_INTERVAL_SECONDS=5
TRAILING_STOP_ENABLED=false
TRAILING_STOP_OFFSET=0.10

# === Gateway ===
APPROVAL_MODE=auto
APPROVAL_TIMEOUT_SECONDS=300

# === General ===
LOG_LEVEL=INFO
