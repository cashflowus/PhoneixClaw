###############################################################################
# PhoenixTrade — Coolify Environment Variables
#
# Copy these into Coolify's Environment Variables panel.
# Variables marked [REQUIRED] must be set before first deploy.
# Variables with defaults are optional — the default will be used if unset.
###############################################################################

# ─── Database (PostgreSQL) ─────────────────────────────────────────────
# [REQUIRED] Strong password for the PostgreSQL database
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_USER=phoenixtrader
POSTGRES_DB=phoenixtrader

# ─── Security — JWT ───────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Security — Credential Encryption ─────────────────────────────────
# [REQUIRED] Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# ─── Discord ──────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs to monitor
DISCORD_TARGET_CHANNELS=

# ─── Trading Execution ───────────────────────────────────────────────
ENABLE_TRADING=true
DRY_RUN_MODE=false
BUFFER_PERCENTAGE=0.15
BUFFER_MAX_PERCENTAGE=0.30
BUFFER_MIN_PRICE=0.01
MAX_POSITION_SIZE=10
MAX_DAILY_LOSS=1000.0

# ─── Trade Approval ──────────────────────────────────────────────────
# "auto" = execute immediately | "manual" = require human approval
APPROVAL_MODE=auto
APPROVAL_TIMEOUT_SECONDS=300

# ─── Position Monitor ────────────────────────────────────────────────
MONITOR_POLL_INTERVAL_SECONDS=5
DEFAULT_PROFIT_TARGET=0.30
DEFAULT_STOP_LOSS=0.20
TRAILING_STOP_ENABLED=false
TRAILING_STOP_OFFSET=0.10

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Build (optional) ────────────────────────────────────────────────
# Increment to force dashboard rebuild (e.g. when Backtesting tab doesn't appear)
# CACHEBUST=2
